# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=

JWT_SECRET=jwt-secret
JWT_EXPIRES_IN=7d

# Google Sign-In — WEB_CLIENT_ID must match EXPO_PUBLIC_WEB_CLIENT_ID in the Expo app
WEB_CLIENT_ID=
GOOGLE_CLIENT_ID=
# Apple Sign-In — iOS bundle ID (com.oqagileathletes.app)
APPLE_CLIENT_ID=com.oqagileathletes.app

# USDA nutrition lookup (required for food scan nutrients)
USDA_API_KEY=

# Food vision — Python microservice (recommended)
# When FOOD_VISION_URL is set, provider defaults to http unless FOOD_VISION_PROVIDER=clarifai
FOOD_VISION_PROVIDER=http
FOOD_VISION_URL=https://food-scanner-python.onrender.com
FOOD_VISION_API_KEY=
FOOD_VISION_TIMEOUT_MS=60000
FOOD_SCAN_MAX_BASE64_CHARS=900000
# Server auto-compresses larger photos before vision (sharp)
FOOD_SCAN_MAX_EDGE_PX=1280
FOOD_SCAN_JPEG_QUALITY=82
# Primary label trusted for meal totals (e.g. 0.5 — below this → visionSuggestion only)
FOOD_SCAN_PRIMARY_MIN_CONFIDENCE=0.5
# Alternates list includes labels at or above this (align with Python MIN_CONFIDENCE)
FOOD_SCAN_ALTERNATE_MIN_CONFIDENCE=0.15
# USDA lookup for alternates only when confidence >= this (saves API calls)
FOOD_SCAN_ALTERNATE_NUTRITION_MIN=0.25
FOOD_SCAN_MAX_ALTERNATES=4

# Clarifai — exercise recognition; optional food fallback (FOOD_VISION_PROVIDER=clarifai)
FitnessOnePAT=
CLARIFAI_API_KEY=
CLARIFAI_TIMEOUT_MS=60000

# ExerciseDB (metadata) — RapidAPI exercisedb.p.rapidapi.com
RAPID_API_KEY=
# Exercises11 (GIF images) — RapidAPI exercises11.p.rapidapi.com; falls back to RAPID_API_KEY if unset
EXERCISES11_RAPID_API_KEY=

# AI Form Coach — Python pose analysis microservice (proxy only; no ML in Node)
FORM_COACH_API_URL=https://agile-athletes-ai-form-coach.onrender.com
FORM_COACH_TIMEOUT_MS=120000
FORM_COACH_HEALTH_CACHE_MS=30000
FORM_COACH_EXERCISES_CACHE_MS=60000
FORM_COACH_RATE_LIMIT_PER_HOUR=10
# FORM_COACH_RATE_LIMIT_DISABLED=true
# MONGO_FORM_ANALYSES_COLLECTION=form_analyses

# AI Trainer chat (POST /chat/*)
COHERE_API_KEY=
# Do not use retired "command" — see https://docs.cohere.com/docs/deprecations
COHERE_MODEL=command-r7b-12-2024
COHERE_TEMPERATURE=0.7
COHERE_TIMEOUT_MS=60000
CHAT_RATE_LIMIT_PER_MINUTE=15
# CHAT_RATE_LIMIT_DISABLED=true
# MONGO_AI_CHAT_COLLECTION=ai_chats

# Account deletion page (optional)
ACCOUNT_DELETION_APP_NAME=
ACCOUNT_DELETION_DEVELOPER_NAME=
ACCOUNT_DELETION_SUPPORT_EMAIL=

# Email (Gmail app password) — fitness workflows + password reset
EMAIL_USER=
EMAIL_APP_PASSWORD=
EMAIL_FROM=
# Display name in emails (welcome strips a leading "OQ " for titles)
# APP_DISPLAY_NAME=Agile Athletes
# Return resetCode in API response (dev only; default off in production)
# EMAIL_EXPOSE_RESET_CODE=true
# Public web origin for email button links (EAS Hosting or Vercel — NOT the API URL)
# Set after deploying Expo web: see EAS_HOSTING_FRONTEND_PROMPT.md
FRONTEND_URL=https://your-project.expo.app

# PT Network — Stripe Connect & bookings
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_COMMISSION_PERCENT=10
POSTCODES_IO_ENABLED=true
# Seed London QA trainers + groups on server start (default on). Set false when using real PTs only.
# SEED_TRAINERS_ON_STARTUP=true

# PT Network — Mongo collections (optional overrides)
# MONGO_TRAINER_PROFILES_COLLECTION=trainer_profiles
# MONGO_TRAINER_LEADS_COLLECTION=trainer_leads
# MONGO_TRAINER_REVIEWS_COLLECTION=trainer_reviews
# MONGO_BOOKING_SLOTS_COLLECTION=booking_slots
# MONGO_BOOKINGS_COLLECTION=bookings
# MONGO_FITNESS_GROUPS_COLLECTION=fitness_groups
# MONGO_PARTNER_CONNECT_COLLECTION=partner_connect_requests
# Optional welcome email header (same host as FRONTEND_URL, HTTPS PNG/JPEG)
# WELCOME_EMAIL_LOGO_URL=https://your-project.expo.app/email/welcome-header.png
DEFAULT_DAILY_STEP_GOAL=8000

# Upstash QStash / Workflow — values from Upstash Console → QStash (EU example below)
QSTASH_URL=https://qstash-eu-central-1.upstash.io
QSTASH_TOKEN=
# Required in production: verify Upstash-Signature on POST /workflow/*
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Public API URL QStash calls (Render). Used when publishing via workflowClient.
# WORKFLOW_CALLBACK_URL=https://api-oq-agile-athletes.onrender.com
# Optional: manual curl without QStash signature (Bearer or x-workflow-secret)
# WORKFLOW_API_SECRET=
WORKFLOW_STEP_REMINDER_HOUR=20
WORKFLOW_WEEKLY_SUMMARY_DAY=0
WORKFLOW_MOTIVATION_INTERVAL_DAYS=7
