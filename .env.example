# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=

# Auth / tokens (set in production)
JWT_SECRET=

# USDA nutrition lookup (required for food scan nutrients)
USDA_API_KEY=

# Food vision — Python microservice (recommended)
# When FOOD_VISION_URL is set, provider defaults to http unless FOOD_VISION_PROVIDER=clarifai
FOOD_VISION_PROVIDER=http
FOOD_VISION_URL=https://food-scanner-python.onrender.com
FOOD_VISION_API_KEY=
FOOD_VISION_TIMEOUT_MS=60000
FOOD_SCAN_MAX_BASE64_CHARS=900000
# Server auto-compresses larger photos before vision (sharp)
FOOD_SCAN_MAX_EDGE_PX=1280
FOOD_SCAN_JPEG_QUALITY=82
FOOD_SCAN_IS_FOOD_CONFIDENCE=0.5
FOOD_SCAN_UNCERTAIN_CONFIDENCE=0.6
FOOD_SCAN_MAX_ALTERNATES=4

# Clarifai — exercise recognition; optional food fallback (FOOD_VISION_PROVIDER=clarifai)
FitnessOnePAT=
CLARIFAI_API_KEY=
CLARIFAI_TIMEOUT_MS=60000

# AI coach
COHERE_API_KEY=
COHERE_MODEL=

# Account deletion page (optional)
ACCOUNT_DELETION_APP_NAME=
ACCOUNT_DELETION_DEVELOPER_NAME=
ACCOUNT_DELETION_SUPPORT_EMAIL=
